{
  "containerDefinitions": [
    {
      "name": "yolo",
      "image": "294060270105.dkr.ecr.ap-southeast-1.amazonaws.com/cooksmart-yolo:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "MLOPS_ENABLED", "value": "false" },
        { "name": "EMBEDDING_ENABLED", "value": "false" },
        { "name": "YOLO_MODEL_PATH", "value": "/app/models/best59.pt" },
        { "name": "YOLO_MODEL_BUCKET", "value": "cooksmart-yolo-models" },
        { "name": "YOLO_MODEL_KEY", "value": "models/best59.pt" },
        { "name": "CONF_INFERENCE_FLOOR", "value": "0.25" },
        { "name": "LOG_LEVEL", "value": "INFO" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cooksmart-prod-v2-yolo",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "cooksmart-yolo-task",
  "taskRoleArn": "arn:aws:iam::294060270105:role/ecsYoloTaskRole",
  "executionRoleArn": "arn:aws:iam::294060270105:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX"
  }
}