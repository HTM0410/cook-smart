{
  "family": "cooksmart-backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "cooksmart-backend",
      "image": "294060270105.dkr.ecr.ap-southeast-1.amazonaws.com/cooksmart-backend:sha-7311176",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "YOLO_SERVICE_CLOUD_URL",
          "value": "http://cooksmart-prod-v2-yolo.cooksmart.local:8000"
        },
        {
          "name": "YOLO_TIMEOUT",
          "value": "5000"
        },
        {
          "name": "YOLO_MAX_RETRIES",
          "value": "1"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cooksmart-backend",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
