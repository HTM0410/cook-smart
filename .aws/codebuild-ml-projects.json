{
  "projects": [
    {
      "name": "cooksmart-ml-validate",
      "description": "Validate training data and code before training",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE",
        "buildspec": "mlops/buildspec/validate.yml"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "aws/codebuild/standard:7.0",
        "computeType": "BUILD_GENERAL1_SMALL",
        "environmentVariables": {
          "AWS_REGION": "ap-southeast-1",
          "TRAIN_YAML": "Data/train.yaml",
          "PARAMS_YAML": "mlops/params.yaml"
        }
      },
      "timeoutInMinutes": 30
    },
    {
      "name": "cooksmart-ml-train",
      "description": "Train YOLO model with wandb logging",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "294060270105.dkr.ecr.ap-southeast-1.amazonaws.com/cooksmart-ml-train:latest",
        "computeType": "BUILD_GENERAL1_LARGE",
        "gpuComputeType": "GPU",
        "environmentVariables": {
          "AWS_REGION": "ap-southeast-1",
          "S3_BUCKET": "cooksmart-models",
          "S3_PREFIX": "ingredient-detector",
          "WANDB_API_KEY": "{{resolve:secretsmanager:wandb-api-key:api_key}}",
          "WANDB_PROJECT": "ingredient-detection",
          "WANDB_ENTITY": "${WANDB_ENTITY}"
        }
      },
      "timeoutInMinutes": 480,
      "queuedTimeoutInMinutes": 720
    },
    {
      "name": "cooksmart-ml-test",
      "description": "Run unit tests on trained model",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "aws/codebuild/standard:7.0",
        "computeType": "BUILD_GENERAL1_MEDIUM",
        "environmentVariables": {
          "MODEL_PATH": "mlops/artifacts/model/best.pt"
        }
      },
      "timeoutInMinutes": 60
    },
    {
      "name": "cooksmart-ml-integration-test",
      "description": "Integration tests with YOLO inference service",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "aws/codebuild/standard:7.0",
        "computeType": "BUILD_GENERAL1_MEDIUM",
        "environmentVariables": {
          "MODEL_PATH": "mlops/artifacts/model/best.pt",
          "YOLO_ENDPOINT": "https://yolo-internal.cooksmart.internal"
        }
      },
      "timeoutInMinutes": 60
    },
    {
      "name": "cooksmart-ml-benchmark",
      "description": "Performance benchmark and metrics validation",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "aws/codebuild/standard:7.0",
        "computeType": "BUILD_GENERAL1_MEDIUM",
        "environmentVariables": {
          "MODEL_PATH": "mlops/artifacts/model/best.pt",
          "TARGET_LATENCY_P95_MS": "3000",
          "MIN_MAP_THRESHOLD": "0.35"
        }
      },
      "timeoutInMinutes": 120
    },
    {
      "name": "cooksmart-ml-register",
      "description": "Register model to S3 and update DynamoDB version table",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "aws/codebuild/standard:7.0",
        "computeType": "BUILD_GENERAL1_SMALL",
        "environmentVariables": {
          "S3_BUCKET": "cooksmart-models",
          "S3_PREFIX": "ingredient-detector",
          "DYNAMODB_TABLE": "cooksmart-model-versions",
          "AWS_REGION": "ap-southeast-1"
        }
      },
      "timeoutInMinutes": 30
    },
    {
      "name": "cooksmart-ml-staging-smoke",
      "description": "Smoke tests on staging environment",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "aws/codebuild/standard:7.0",
        "computeType": "BUILD_GENERAL1_SMALL",
        "environmentVariables": {
          "ENVIRONMENT": "staging",
          "YOLO_ENDPOINT": "https://yolo-staging.cooksmart.internal"
        }
      },
      "timeoutInMinutes": 30
    },
    {
      "name": "cooksmart-ml-promote-alias",
      "description": "Promote model alias from candidate to production",
      "serviceRole": "arn:aws:iam::294060270105:role/codepipeline-ml-build-role",
      "source": {
        "type": "CODEPIPELINE"
      },
      "artifacts": {
        "type": "CODEPIPELINE"
      },
      "environment": {
        "type": "LINUX_CONTAINER",
        "image": "aws/codebuild/standard:7.0",
        "computeType": "BUILD_GENERAL1_SMALL",
        "environmentVariables": {
          "DYNAMODB_TABLE": "cooksmart-model-versions",
          "ALIAS": "production",
          "AWS_REGION": "ap-southeast-1"
        }
      },
      "timeoutInMinutes": 15
    }
  ]
}
