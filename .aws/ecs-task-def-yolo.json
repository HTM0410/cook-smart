{
  "family": "cooksmart-yolo-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "executionRoleArn": "arn:aws:iam::294060270105:role/ecsTaskExecutionRole",
  "cpu": "2048",
  "memory": "4096",
  "containerDefinitions": [
    {
      "name": "yolo",
      "image": "294060270105.dkr.ecr.ap-southeast-1.amazonaws.com/cooksmart-yolo:sha-b35be1a",
      "essential": true,
      "portMappings": [
        {
          "name": "yolo",
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "MLOPS_ENABLED",
          "value": "false"
        },
        {
          "name": "EMBEDDING_ENABLED",
          "value": "false"
        },
        {
          "name": "CONF_INFERENCE_FLOOR",
          "value": "0.25"
        },
        {
          "name": "YOLO_MODEL_PATH",
          "value": "/app/models/best59.pt"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        }
      ],
      "secrets": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cooksmart-prod-v2-yolo",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 120
      }
    }
  ]
}
