{
  "family": "cooksmart-backend-task",
  "taskRoleArn": "arn:aws:iam::294060270105:role/cooksmart-backend-task-role",
  "executionRoleArn": "arn:aws:iam::294060270105:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "containerDefinitions": [
    {
      "name": "cooksmart-backend",
      "image": "294060270105.dkr.ecr.ap-southeast-1.amazonaws.com/cooksmart-backend:sha-7311176",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "NODE_ENV", "value": "production"},
        {"name": "PORT", "value": "3000"},
        {"name": "YOLO_SERVICE_CLOUD_URL", "value": "http://cooksmart-prod-v2-yolo.cooksmart.local:8000"},
        {"name": "YOLO_TIMEOUT", "value": "5000"},
        {"name": "YOLO_MAX_RETRIES", "value": "1"},
        {"name": "CORS_ORIGIN", "value": "https://cooksmart.netlify.app,https://cookssmart.netlify.app,https://cooksmart.click,https://api.cooksmart.click"},
        {"name": "CLIENT_URL", "value": "https://cooksmart.netlify.app,https://cookssmart.netlify.app,https://cooksmart.click"},
        {"name": "REDIS_ENABLED", "value": "false"},
        {"name": "MLOPS_ENABLED", "value": "true"},
        {"name": "EMBEDDING_ENABLED", "value": "false"},
        {"name": "ELASTICSEARCH_ENABLED", "value": "false"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cooksmart-backend",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
