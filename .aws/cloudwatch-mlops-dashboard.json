{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# CookSmart MLOps Production Dashboard\nECS cluster: `cooksmart-prod-v2` | Registry: S3 + DynamoDB | Drift cron: every 6h"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 1,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "ECS YOLO Service - CPU & Memory",
        "metrics": [
          ["AWS/ECS", "CPUUtilization", "ServiceName", "cooksmart-prod-v2-yolo-svc", "ClusterName", "cooksmart-prod-v2"],
          [".", "MemoryUtilization", ".", ".", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Average"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 1,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "ECS Backend Service - CPU & Memory",
        "metrics": [
          ["AWS/ECS", "CPUUtilization", "ServiceName", "cooksmart-backend", "ClusterName", "cooksmart-prod-v2"],
          [".", "MemoryUtilization", ".", ".", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Average"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 7,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "YOLO Inference Latency (target = p95 < 3s)",
        "metrics": [
          ["cooksmart-prod-v2", "yolo_inference_duration_seconds", "model_source", "s3"]
        ],
        "region": "ap-southeast-1",
        "period": 60,
        "stat": "p95"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 7,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "YOLO Request Count (5xx vs 2xx)",
        "metrics": [
          ["cooksmart-prod-v2", "yolo_requests_total", "status", "2xx"],
          ["...", ".", ".", "5xx"]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Sum"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 13,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "DynamoDB Model Registry - Throttled Requests",
        "metrics": [
          ["AWS/DynamoDB", "ThrottledRequests", "TableName", "cooksmart-model-versions"]
        ],
        "region": "ap-southeast-1",
        "period": 60,
        "stat": "Sum"
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 13,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "S3 cooksmart-models - 5xx Errors",
        "metrics": [
          ["AWS/S3", "5xxErrors", "BucketName", "cooksmart-models"],
          [".", "4xxErrors", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Sum"
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 13,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Lambda drift-job - Invocations & Errors",
        "metrics": [
          ["AWS/Lambda", "Invocations", "FunctionName", "cooksmart-prod-v2-drift-job"],
          [".", "Errors", ".", "."],
          [".", "Duration", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 3600,
        "stat": "Sum"
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 19,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "YOLO Service Recent Logs (model loading)",
        "query": "SOURCE '/ecs/cooksmart-prod-v2-yolo' | fields @timestamp, @message\n| filter @message like /registry|s3|MLOps/\n| sort @timestamp desc\n| limit 20",
        "region": "ap-southeast-1"
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 25,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "Drift Lambda Recent Logs",
        "query": "SOURCE '/aws/lambda/cooksmart-prod-v2-drift-job' | fields @timestamp, @message\n| sort @timestamp desc\n| limit 20",
        "region": "ap-southeast-1"
      }
    }
  ]
}