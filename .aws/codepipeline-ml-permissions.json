{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "codebuild:BatchGetBuilds",
        "codebuild:StartBuild",
        "codebuild:StopBuild",
        "codebuild:ReportBuildStatus"
      ],
      "Resource": [
        "arn:aws:codebuild:ap-southeast-1:294060270105:project/cooksmart-ml-*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "codedeploy:CreateDeployment",
        "codedeploy:GetDeployment",
        "codedeploy:GetDeploymentConfig",
        "codedeploy:RegisterApplicationRevision",
        "codedeploy:StopDeployment"
      ],
      "Resource": [
        "arn:aws:codedeploy:ap-southeast-1:294060270105:application:cooksmart-yolo-app",
        "arn:aws:codedeploy:ap-southeast-1:294060270105:deploymentgroup:cooksmart-yolo-app/*",
        "arn:aws:codedeploy:ap-southeast-1:294060270105:deploymentconfig:cooksmart-yolo-*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "codepipeline:StartPipelineExecution",
        "codepipeline:GetPipelineState",
        "codepipeline:GetPipelineExecution"
      ],
      "Resource": [
        "arn:aws:codepipeline:ap-southeast-1:294060270105:pipeline:cooksmart-ml-training-pipeline"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::cooksmart-models",
        "arn:aws:s3:::cooksmart-models/*",
        "arn:aws:s3:::cooksmart-training-data",
        "arn:aws:s3:::cooksmart-training-data/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-southeast-1:294060270105:table/cooksmart-model-versions"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "sns:Publish"
      ],
      "Resource": "arn:aws:sns:ap-southeast-1:294060270105:*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "sts:AssumeRole"
      ],
      "Resource": "arn:aws:iam::294060270105:role/codepipeline-ml-*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeFunction"
      ],
      "Resource": [
        "arn:aws:lambda:ap-southeast-1:294060270105:function:cooksmart-*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "events:PutEvents"
      ],
      "Resource": "*"
    }
  ]
}
