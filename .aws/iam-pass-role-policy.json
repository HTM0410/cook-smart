{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PassTaskAndExecutionRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::294060270105:role/cooksmart-backend-task-role",
        "arn:aws:iam::294060270105:role/ecsYoloTaskRole",
        "arn:aws:iam::294060270105:role/cooksmart-prod-v2-task-role",
        "arn:aws:iam::294060270105:role/cooksmart-prod-v2-task-execution-role",
        "arn:aws:iam::294060270105:role/ecsTaskExecutionRole"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": [
            "ecs-tasks.amazonaws.com",
            "ecs.amazonaws.com"
          ]
        }
      }
    }
  ]
}