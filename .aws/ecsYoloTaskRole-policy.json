{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "YoloS3RegistryRead",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::cooksmart-models",
        "arn:aws:s3:::cooksmart-models/*",
        "arn:aws:s3:::cooksmart-yolo-models",
        "arn:aws:s3:::cooksmart-yolo-models/*"
      ]
    },
    {
      "Sid": "YoloDynamoDBRegistryRead",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:DescribeTable"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-southeast-1:294060270105:table/cooksmart-model-versions",
        "arn:aws:dynamodb:ap-southeast-1:294060270105:table/cooksmart-model-versions/index/*"
      ]
    },
    {
      "Sid": "YoloCloudWatchMetrics",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "cloudwatch:namespace": "cooksmart-prod-v2"
        }
      }
    }
  ]
}