{
  "containerDefinitions": [
    {
      "name": "pg-migrator",
      "image": "postgres:17-alpine",
      "essential": true,
      "command": ["sleep", "3600"],
      "environment": [
        { "name": "OLD_DB_HOST", "value": "aws-1-ap-northeast-1.pooler.supabase.com" },
        { "name": "OLD_DB_PORT", "value": "6543" },
        { "name": "OLD_DB_USER", "value": "postgres.hcswzmpqkhtqdwbhevqb" },
        { "name": "OLD_DB_PASSWORD", "value": "hoanghhk123." },
        { "name": "OLD_DB_NAME", "value": "postgres" },
        { "name": "NEW_DB_HOST", "value": "aws-0-ap-southeast-1.pooler.supabase.com" },
        { "name": "NEW_DB_PORT", "value": "6543" },
        { "name": "NEW_DB_USER", "value": "postgres.dbdsrdtofmhlluxgrfok" },
        { "name": "NEW_DB_PASSWORD", "value": "hoanghhk123." },
        { "name": "NEW_DB_NAME", "value": "postgres" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
