{
  "applicationName": "cooksmart-yolo-app",
  "deploymentStyle": {
    "deploymentType": "BLUE_GREEN",
    "deploymentOption": "WITH_TRAFFIC_CONTROL"
  },
  "deploymentConfig": {
    "deploymentConfigName": "CodeDeployDefault.Canary10PercentAllAtOnce",
    "trafficRoutingConfig": {
      "type": "TimeBasedCanary",
      "timeBasedCanary": {
        "stepPercentageCanary": 10,
        "interval": 5
      }
    }
  },
  "deploymentGroups": [
    {
      "deploymentGroupName": "cooksmart-yolo-staging",
      "deploymentStyle": {
        "deploymentType": "BLUE_GREEN",
        "deploymentOption": "WITH_TRAFFIC_CONTROL"
      },
      "loadBalancerInfo": {
        "targetGroupPairInfo": {
          "targetGroups": [
            {
              "name": "cooksmart-yolo-tg-blue"
            },
            {
              "name": "cooksmart-yolo-tg-green"
            }
          ],
          "prodTrafficRoute": {
            "listenerArns": [
              "arn:aws:elasticloadbalancing:ap-southeast-1:294060270105:listener/app/cooksmart-alb/xxx/yyy"
            ]
          },
          "testTrafficRoute": {
            "listenerArns": [
              "arn:aws:elasticloadbalancing:ap-southeast-1:294060270105:listener/app/cooksmart-alb/xxx/test-yolo"
            ]
          }
        }
      },
      "autoRollbackConfiguration": {
        "enabled": true,
        "events": [
          "DEPLOYMENT_FAILURE",
          "DEPLOYMENT_STOP_ON_ALARM"
        ]
      },
      "alarmConfiguration": {
        "enabled": true,
        "alarms": [
          {
            "name": "cooksmart-yolo-high-error-rate"
          },
          {
            "name": "cooksmart-yolo-high-latency"
          }
        ],
        "ignorePollAlarmFailure": false
      },
      "ec2TagSet": {
        "ec2TagSetList": []
      },
      "ecsServices": [
        {
          "serviceName": "cooksmart-yolo-staging-svc",
          "clusterName": "cooksmart-staging"
        }
      ]
    },
    {
      "deploymentGroupName": "cooksmart-yolo-production",
      "deploymentStyle": {
        "deploymentType": "BLUE_GREEN",
        "deploymentOption": "WITH_TRAFFIC_CONTROL"
      },
      "loadBalancerInfo": {
        "targetGroupPairInfo": {
          "targetGroups": [
            {
              "name": "cooksmart-yolo-prod-tg-blue"
            },
            {
              "name": "cooksmart-yolo-prod-tg-green"
            }
          ],
          "prodTrafficRoute": {
            "listenerArns": [
              "arn:aws:elasticloadbalancing:ap-southeast-1:294060270105:listener/app/cooksmart-prod-alb/xxx/prod-yolo"
            ]
          },
          "testTrafficRoute": {
            "listenerArns": [
              "arn:aws:elasticloadbalancing:ap-southeast-1:294060270105:listener/app/cooksmart-prod-alb/xxx/test-yolo"
            ]
          }
        }
      },
      "autoRollbackConfiguration": {
        "enabled": true,
        "events": [
          "DEPLOYMENT_FAILURE",
          "DEPLOYMENT_STOP_ON_ALARM"
        ]
      },
      "alarmConfiguration": {
        "enabled": true,
        "alarms": [
          {
            "name": "cooksmart-prod-yolo-5xx-error-rate"
          },
          {
            "name": "cooksmart-prod-yolo-p95-latency"
          }
        ],
        "ignorePollAlarmFailure": false
      },
      "deploymentConfigName": "CodeDeployDefault.Canary10PercentAllAtOnce",
      "ec2TagSet": {
        "ec2TagSetList": []
      },
      "ecsServices": [
        {
          "serviceName": "cooksmart-prod-v2-yolo-svc",
          "clusterName": "cooksmart-prod-v2"
        }
      ]
    }
  ]
}
