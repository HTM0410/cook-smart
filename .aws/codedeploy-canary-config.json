{
  "deploymentConfigName": "cooksmart-yolo-canary-10",
  "deploymentConfigFn": "AWS::CodeDeploy::DeploymentConfig",
  "deploymentConfigProperty": {
    "minimumHealthyHosts": {
      "type": "FLEET_PERCENT",
      "value": 90
    },
    "trafficRoutingConfig": {
      "type": "TimeBasedCanary",
      "timeBasedCanary": {
        "stepPercentageCanary": 10,
        "interval": 5
      }
    },
    "computePlatform": "ECS"
  },
  "description": "Canary deployment: 10% traffic for 5 minutes, then 100%"
}
