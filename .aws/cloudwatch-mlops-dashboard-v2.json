{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# CookSmart MLOps Production Dashboard\nECS cluster: `cooksmart-prod-v2` | Registry: S3 + DynamoDB | Drift cron: every 6h\n---\n## Training Pipeline Status"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Pipeline Executions (24h)",
        "metrics": [
          ["CookSmart/MLOps", "PipelineExecutions", "Status", "Succeeded"],
          [".", "PipelineExecutions", "Status", "Failed"],
          [".", "PipelineExecutions", "Status", "InProgress"]
        ],
        "region": "ap-southeast-1",
        "period": 3600,
        "stat": "Sum"
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Training Duration (minutes)",
        "metrics": [
          ["CookSmart/MLOps", "TrainingDuration", "Branch", "main"]
        ],
        "region": "ap-southeast-1",
        "period": 86400,
        "stat": "Average"
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Model mAP@0.5 (Latest)",
        "metrics": [
          ["CookSmart/MLOps", "ModelMap50", "Version", "latest"]
        ],
        "region": "ap-southeast-1",
        "period": 86400,
        "stat": "Maximum"
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 7,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## Inference Service"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 8,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "ECS YOLO Service - CPU & Memory",
        "metrics": [
          ["AWS/ECS", "CPUUtilization", "ServiceName", "cooksmart-prod-v2-yolo-svc", "ClusterName", "cooksmart-prod-v2"],
          [".", "MemoryUtilization", ".", ".", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Average"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 8,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "ECS Backend Service - CPU & Memory",
        "metrics": [
          ["AWS/ECS", "CPUUtilization", "ServiceName", "cooksmart-backend", "ClusterName", "cooksmart-prod-v2"],
          [".", "MemoryUtilization", ".", ".", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Average"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 14,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "YOLO Inference Latency (target = p95 < 3s)",
        "metrics": [
          ["cooksmart-prod-v2", "yolo_inference_duration_seconds", "model_source", "s3"],
          [".", "yolo_inference_duration_seconds", "model_source", "wandb"],
          [".", "yolo_inference_duration_seconds", "model_source", "local"]
        ],
        "region": "ap-southeast-1",
        "period": 60,
        "stat": "p95"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 14,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "YOLO Request Count (2xx vs 5xx)",
        "metrics": [
          ["cooksmart-prod-v2", "yolo_requests_total", "status", "2xx"],
          [".", "yolo_requests_total", "status", "5xx"]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Sum"
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 20,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## Drift Detection"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 21,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Drift Alert Level (0=None, 1=Warning, 2=Critical)",
        "metrics": [
          ["cooksmart-prod-v2", "drift_alert"]
        ],
        "region": "ap-southeast-1",
        "period": 21600,
        "stat": "Maximum"
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 21,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Data Drift (min p-value)",
        "metrics": [
          ["cooksmart-prod-v2", "drift_data_p_value_min"]
        ],
        "region": "ap-southeast-1",
        "period": 21600,
        "stat": "Minimum"
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 21,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Prediction Drift (JSD)",
        "metrics": [
          ["cooksmart-prod-v2", "drift_prediction_jsd"]
        ],
        "region": "ap-southeast-1",
        "period": 21600,
        "stat": "Maximum"
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 27,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## Model Registry & Storage"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 28,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "DynamoDB Model Registry - Throttled Requests",
        "metrics": [
          ["AWS/DynamoDB", "ThrottledRequests", "TableName", "cooksmart-model-versions"]
        ],
        "region": "ap-southeast-1",
        "period": 60,
        "stat": "Sum"
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 28,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "S3 cooksmart-models - 5xx Errors",
        "metrics": [
          ["AWS/S3", "5xxErrors", "BucketName", "cooksmart-models"],
          [".", "4xxErrors", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Sum"
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 28,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Lambda drift-job - Invocations",
        "metrics": [
          ["AWS/Lambda", "Invocations", "FunctionName", "cooksmart-prod-v2-drift-job"],
          [".", "Errors", ".", "."],
          [".", "Duration", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 3600,
        "stat": "Sum"
      }
    },
    {
      "type": "text",
      "x": 0,
      "y": 34,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "## Deployment Status"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 35,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "CodeDeploy - Active Deployments",
        "metrics": [
          ["AWS/CodeDeploy", "Deployments", "ApplicationName", "cooksmart-yolo-app", "DeploymentGroup", "cooksmart-yolo-production"],
          [".", "DeploymentStatus", ".", ".", ".", "."]
        ],
        "region": "ap-southeast-1",
        "period": 300,
        "stat": "Average"
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 35,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Canary Traffic Percentage",
        "metrics": [
          ["AWS/CodeDeploy", "CanaryTraffic", "ApplicationName", "cooksmart-yolo-app"]
        ],
        "region": "ap-southeast-1",
        "period": 60,
        "stat": "Maximum"
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 35,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Auto Rollback Events",
        "metrics": [
          ["AWS/CodeDeploy", "AutoRollbacks", "ApplicationName", "cooksmart-yolo-app"]
        ],
        "region": "ap-southeast-1",
        "period": 86400,
        "stat": "Sum"
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 41,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "YOLO Service Recent Logs (model loading)",
        "query": "SOURCE '/ecs/cooksmart-prod-v2-yolo' | fields @timestamp, @message\n| filter @message like /registry|s3|MLOps|best.pt/\n| sort @timestamp desc\n| limit 20",
        "region": "ap-southeast-1"
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 47,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Drift Lambda Recent Logs",
        "query": "SOURCE '/aws/lambda/cooksmart-prod-v2-drift-job' | fields @timestamp, @message\n| filter @message like /drift|alert|p-value/\n| sort @timestamp desc\n| limit 15",
        "region": "ap-southeast-1"
      }
    },
    {
      "type": "log",
      "x": 12,
      "y": 47,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Pipeline Build Logs",
        "query": "SOURCE '/aws/codebuild/ml-training' | fields @timestamp, @message\n| filter @message like /Training|model|success/\n| sort @timestamp desc\n| limit 15",
        "region": "ap-southeast-1"
      }
    }
  ]
}
