{
  "pipeline": {
    "name": "cooksmart-ml-training-pipeline",
    "roleArn": "arn:aws:iam::294060270105:role/codepipeline-ml-training-role",
    "artifactStore": {
      "type": "S3",
      "location": "cooksmart-models"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "SourceCode",
            "actionTypeId": {
              "category": "Source",
              "owner": "ThirdParty",
              "provider": "GitHub",
              "version": "1"
            },
            "configuration": {
              "Owner": "${GITHUB_OWNER}",
              "Repo": "${GITHUB_REPO}",
              "Branch": "${BRANCH_NAME}",
              "OAuthToken": "{{resolve:secretsmanager:github-token:token}}",
              "PollForSourceChanges": false
            },
            "outputArtifacts": [
              {
                "name": "SourceCode"
              }
            ]
          },
          {
            "name": "SourceData",
            "actionTypeId": {
              "category": "Source",
              "owner": "AWS",
              "provider": "S3",
              "version": "1"
            },
            "configuration": {
              "S3Location": {
                "Bucket": "cooksmart-training-data",
                "ObjectKey": "datasets/ingredient-detection/latest"
              },
              "PollForSourceChanges": true
            },
            "outputArtifacts": [
              {
                "name": "TrainingData"
              }
            ]
          }
        ]
      },
      {
        "name": "Validate",
        "actions": [
          {
            "name": "ValidateCode",
            "actionTypeId": {
              "category": "Test",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-validate",
              "EnvironmentVariables": {
                "TRAIN_YAML": "Data/train.yaml",
                "PARAMS_YAML": "mlops/params.yaml"
              }
            },
            "inputArtifacts": [
              {
                "name": "SourceCode"
              }
            ],
            "outputArtifacts": [
              {
                "name": "ValidationResult"
              }
            ]
          }
        ]
      },
      {
        "name": "Build",
        "actions": [
          {
            "name": "TrainModel",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-train",
              "EnvironmentVariables": {
                "AWS_REGION": "ap-southeast-1",
                "S3_BUCKET": "cooksmart-models",
                "S3_PREFIX": "ingredient-detector",
                "MODEL_VERSION": "#{metadata.version}",
                "WANDB_API_KEY": "{{resolve:secretsmanager:wandb-api-key:api_key}}",
                "WANDB_PROJECT": "ingredient-detection",
                "WANDB_ENTITY": "${WANDB_ENTITY}",
                "BRANCH_NAME": "#{Source.SourceCodeVariables.BranchName}",
                "COMMIT_SHA": "#{Source.SourceCodeVariables.CommitId}"
              }
            },
            "inputArtifacts": [
              {
                "name": "SourceCode"
              },
              {
                "name": "TrainingData"
              }
            ],
            "outputArtifacts": [
              {
                "name": "TrainedModel"
              }
            ]
          }
        ]
      },
      {
        "name": "Test",
        "actions": [
          {
            "name": "UnitTests",
            "actionTypeId": {
              "category": "Test",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-test",
              "EnvironmentVariables": {
                "MODEL_PATH": "mlops/artifacts/model/best.pt"
              }
            },
            "inputArtifacts": [
              {
                "name": "TrainedModel"
              }
            ]
          },
          {
            "name": "IntegrationTests",
            "actionTypeId": {
              "category": "Test",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-integration-test",
              "EnvironmentVariables": {
                "MODEL_PATH": "mlops/artifacts/model/best.pt",
                "YOLO_ENDPOINT": "https://yolo-internal.cooksmart.internal"
              }
            },
            "inputArtifacts": [
              {
                "name": "TrainedModel"
              }
            ]
          },
          {
            "name": "PerformanceBenchmark",
            "actionTypeId": {
              "category": "Test",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-benchmark",
              "EnvironmentVariables": {
                "MODEL_PATH": "mlops/artifacts/model/best.pt",
                "TARGET_LATENCY_P95_MS": "3000",
                "MIN_MAP_THRESHOLD": "0.35"
              }
            },
            "inputArtifacts": [
              {
                "name": "TrainedModel"
              }
            ]
          }
        ]
      },
      {
        "name": "RegisterModel",
        "actions": [
          {
            "name": "UploadToS3",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-register",
              "EnvironmentVariables": {
                "S3_BUCKET": "cooksmart-models",
                "S3_PREFIX": "ingredient-detector",
                "REGISTRY": "s3",
                "ALIAS": "candidate",
                "GIT_REVISION": "#{Source.SourceCodeVariables.CommitId}",
                "GIT_BRANCH": "#{Source.SourceCodeVariables.BranchName}"
              }
            },
            "inputArtifacts": [
              {
                "name": "TrainedModel"
              },
              {
                "name": "ValidationResult"
              }
            ],
            "outputArtifacts": [
              {
                "name": "RegisteredModel"
              }
            ]
          }
        ]
      },
      {
        "name": "DeployToStaging",
        "actions": [
          {
            "name": "DeployCanary",
            "actionTypeId": {
              "category": "Deploy",
              "owner": "AWS",
              "provider": "CodeDeploy",
              "version": "1"
            },
            "configuration": {
              "ApplicationName": "cooksmart-yolo-app",
              "DeploymentGroupName": "cooksmart-yolo-staging",
              "DeploymentStrategyName": "CanaryWithExtraTraffic",
              "AdditionalConfiguration": [
                {
                  "Key": "trafficPercentage",
                  "Value": "10"
                }
              ]
            },
            "inputArtifacts": [
              {
                "name": "RegisteredModel"
              }
            ],
            "runOrder": 1
          },
          {
            "name": "SmokeTest",
            "actionTypeId": {
              "category": "Test",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-staging-smoke",
              "EnvironmentVariables": {
                "ENVIRONMENT": "staging",
                "SMOKE_TEST_IMAGE": "tests/fixtures/test_ingredients.jpg"
              }
            },
            "runOrder": 2
          }
        ]
      },
      {
        "name": "DeployToProduction",
        "actions": [
          {
            "name": "ApprovePromotion",
            "actionTypeId": {
              "category": "Approval",
              "owner": "AWS",
              "provider": "Manual",
              "version": "1"
            },
            "configuration": {
              "NotificationArn": "${SNS_TOPIC_ARN}",
              "CustomData": "Model ready for production. Check metrics at: ${CLOUDWATCH_DASHBOARD_URL}"
            }
          },
          {
            "name": "PromoteToProduction",
            "actionTypeId": {
              "category": "Deploy",
              "owner": "AWS",
              "provider": "CodeDeploy",
              "version": "1"
            },
            "configuration": {
              "ApplicationName": "cooksmart-yolo-app",
              "DeploymentGroupName": "cooksmart-yolo-production",
              "DeploymentStrategyName": "Canary10PercentAllAtOnce"
            },
            "inputArtifacts": [
              {
                "name": "RegisteredModel"
              }
            ],
            "runOrder": 2
          },
          {
            "name": "UpdateAlias",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": {
              "ProjectName": "cooksmart-ml-promote-alias",
              "EnvironmentVariables": {
                "DYNAMODB_TABLE": "cooksmart-model-versions",
                "ALIAS": "production",
                "NEW_VERSION": "#{RegisterModel.UploadToS3.Version}"
              }
            },
            "inputArtifacts": [
              {
                "name": "RegisteredModel"
              }
            ],
            "runOrder": 3
          }
        ]
      }
    ]
  }
}
