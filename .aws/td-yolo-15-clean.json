{
  "containerDefinitions": [
    {
      "name": "yolo",
      "image": "294060270105.dkr.ecr.ap-southeast-1.amazonaws.com/cooksmart-yolo:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "name": "yolo"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "S3_MODEL_BUCKET",
          "value": "cooksmart-models"
        },
        {
          "name": "MLOPS_ENABLED",
          "value": "true"
        },
        {
          "name": "AWS_REGION",
          "value": "ap-southeast-1"
        },
        {
          "name": "EMBEDDING_ENABLED",
          "value": "false"
        },
        {
          "name": "YOLO_MODEL_PATH",
          "value": "/app/models/best59.pt"
        },
        {
          "name": "MLOPS_REGISTRY",
          "value": "s3"
        },
        {
          "name": "CONF_INFERENCE_FLOOR",
          "value": "0.25"
        },
        {
          "name": "DYNAMODB_MODEL_TABLE",
          "value": "cooksmart-model-versions"
        },
        {
          "name": "LOG_LEVEL",
          "value": "INFO"
        },
        {
          "name": "S3_MODEL_PREFIX",
          "value": "ingredient-detector/"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cooksmart-prod-v2-yolo",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 30,
        "retries": 5,
        "startPeriod": 300
      },
      "systemControls": []
    }
  ],
  "family": "cooksmart-yolo-task",
  "taskRoleArn": "arn:aws:iam::294060270105:role/ecsYoloTaskRole",
  "executionRoleArn": "arn:aws:iam::294060270105:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "2048",
  "memory": "4096"
}
