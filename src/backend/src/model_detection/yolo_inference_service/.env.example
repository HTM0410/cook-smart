# YOLO Inference Service Environment Variables

# Model Configuration
YOLO_MODEL_PATH=./best59.pt
YOLO_LABEL_MAPPING_PATH=./label_mapping.json
CONF_INFERENCE_FLOOR=0.25

# CPU/GPU Configuration (leave empty for CPU only)
CUDA_VISIBLE_DEVICES=

# Embedding Model Configuration
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32

# MLOps Configuration (for cloud deployments)
MLOPS_ENABLED=false
MLOPS_REGISTRY=wandb
WANDB_API_KEY=replace_with_your_wandb_key
WANDB_ENTITY=replace_with_your_wandb_entity
WANDB_PROJECT=ingredient-detection
WANDB_MODEL_ARTIFACT=ingredient-detector
WANDB_MODEL_ALIAS=production
WANDB_MODEL_CACHE=/tmp/food-suggest-models

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Monitoring (leave empty locally; use a strong token in production)
METRICS_TOKEN=
