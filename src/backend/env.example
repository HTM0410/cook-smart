# Database Configuration
# Supabase PostgreSQL (đang sử dụng)
# Cách 1: Sử dụng connection string (khuyến nghị)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.exyrnohfcysmbsywtpjx.supabase.co:5432/postgres

# Cách 2: Sử dụng thông tin riêng lẻ
SUPABASE_DB_HOST=db.exyrnohfcysmbsywtpjx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASS=[YOUR-PASSWORD]

# MySQL (đã chuyển sang Supabase, không dùng nữa)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=cooksmart
# DB_USER=root
# DB_PASS=your_password_here

DB_SYNC_ALTER=false

# JWT Configuration
JWT_SECRET=super_secret_key
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3000
NODE_ENV=development

# Monitoring (set a strong token in production)
METRICS_TOKEN=
LOG_LEVEL=info
GRAFANA_URL=http://localhost:3001/d/food-suggest-mlops

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Redis Configuration (for caching)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch Configuration (for autocomplete)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_ENABLED=false

# Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
