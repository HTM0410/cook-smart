# ============================================
# Database Configuration
# ============================================
SUPABASE_DB_URL=postgresql://postgres:password@host:6543/postgres?sslmode=require
# Or use individual settings:
# SUPABASE_DB_HOST=your-db.supabase.co
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASS=your_password

# ============================================
# Authentication
# ============================================
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ============================================
# Gemini API (for RAG Chatbot)
# ============================================
# Single API key:
GEMINI_API_KEY=your_gemini_api_key_here

# OR Multiple API keys (comma-separated, for load balancing):
# GEMINI_API_KEYS=key1,key2,key3,key4,key5

GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Models ordered by priority (lightest & most stable first):
# gemini-3.0-flash-lite > gemini-2.0-flash-lite > gemini-2.0-flash > gemini-1.5-flash-8b > gemini-1.5-flash > gemini-2.5-flash

# ============================================
# Vector Search Configuration
# ============================================
EMBEDDING_DIMENSION=3072

# ============================================
# Cloudinary (Image Upload)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Redis Cache
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Elasticsearch (Optional)
# ============================================
ELASTICSEARCH_NODE=http://localhost:9200

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Database sync settings
# Set to 'true' only for development to auto-alter tables
DB_SYNC_ALTER=false

# ============================================
# Monitoring
# ============================================
# Leave empty for local Prometheus. Set a strong token in production.
METRICS_TOKEN=
LOG_LEVEL=info
GRAFANA_URL=http://localhost:3001/d/food-suggest-mlops
