{
  "name": "cooksmart-backend",
  "version": "1.0.0",
  "description": "Backend API for CookSmart application",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "postinstall": "npm run build",
    "build:render": "npm install --include=dev && npm run build",
    "dev": "concurrently --kill-others-on-fail -n \"YOLO,API\" -c \"yellow,cyan\" \"npm run yolo:start\" \"npx ts-node src/server.ts\"",
    "yolo:start": "powershell -ExecutionPolicy Bypass -File start-yolo.ps1",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:conflicts": "npx ts-node src/seeders/ingredient-conflicts.seeder.ts",
    "db:reset": "npx sequelize-cli db:migrate:undo:all && npm run db:migrate && npm run db:seed"
  },
  "keywords": [
    "food",
    "recipe",
    "suggestion",
    "api",
    "nodejs",
    "express",
    "sequelize"
  ],
  "author": "Food Suggest Team",
  "license": "MIT",
  "dependencies": {
    "@elastic/elasticsearch": "^9.1.1",
    "@google/generative-ai": "^0.21.0",
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.0",
    "@langchain/google-genai": "^2.2.0",
    "@types/redis": "^4.0.10",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "concurrently": "^9.2.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "fuse.js": "^7.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.5.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "redis": "^5.8.3",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-jwt": "^6.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.8.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
