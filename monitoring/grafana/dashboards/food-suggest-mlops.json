{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "DOWN"}, "1": {"color": "green", "text": "UP"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "textMode": "auto"},
      "targets": [{"expr": "up{job=\"cooksmart-backend\"}", "refId": "A"}],
      "title": "Node Backend",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "NOT LOADED"}, "1": {"color": "green", "text": "LOADED"}}, "type": "value"}]}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}},
      "targets": [{"expr": "yolo_model_loaded", "refId": "A"}],
      "title": "YOLO Model",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}},
      "targets": [{"expr": "sum(rate(cooksmart_http_requests_total[5m]))", "refId": "A"}],
      "title": "Backend Request Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}},
      "targets": [{"expr": "sum(rate(cooksmart_http_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(cooksmart_http_requests_total[5m])), 0.001)", "refId": "A"}],
      "title": "Backend 5xx Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(cooksmart_http_request_duration_seconds_bucket[5m])))", "legendFormat": "Backend p95", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(yolo_inference_duration_seconds_bucket[5m])))", "legendFormat": "YOLO inference p95", "refId": "B"}
      ],
      "title": "Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "topk(10, sum by (class_name) (rate(yolo_detections_total[10m])))", "legendFormat": "{{class_name}}", "refId": "A"}],
      "title": "Top Detected Ingredients",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "histogram_quantile(0.50, sum by (le) (rate(yolo_detection_confidence_bucket[10m])))", "legendFormat": "Median confidence", "refId": "A"}],
      "title": "Detection Confidence",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [{"expr": "sum by (endpoint) (rate(yolo_empty_results_total[10m]))", "legendFormat": "{{endpoint}}", "refId": "A"}],
      "title": "Empty Detection Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "MISMATCH"}, "1": {"color": "green", "text": "OK"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 19},
      "id": 9,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "textMode": "auto"},
      "targets": [{"expr": "yolo_model_schema_compatible", "refId": "A"}],
      "title": "Model Schema",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 4, "w": 18, "x": 6, "y": 19},
      "id": 10,
      "options": {"showHeader": true},
      "targets": [{"expr": "yolo_model_info", "format": "table", "instant": true, "refId": "A"}],
      "title": "Loaded Model Version",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["food-suggest", "mlops", "yolo"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
