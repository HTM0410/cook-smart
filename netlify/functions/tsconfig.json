{
  "extends": "../../src/backend/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "../../src/backend/src/*": ["../../src/backend/src/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "*.ts",
    "../../src/backend/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
